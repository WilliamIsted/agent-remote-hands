# Line-ending normalisation
#
# Default: Git auto-detects text vs binary, normalises text to LF in the repo,
# and converts to the platform's native line ending on checkout (controlled by
# the developer's core.autocrlf setting). Overrides below pin specific file
# types to LF or CRLF where the format requires it.

* text=auto

# Always LF — these break with CRLF on POSIX systems
*.sh    text eol=lf

# Always CRLF — Windows-native shells and Visual Studio tooling expect it
*.cmd            text eol=crlf
*.bat            text eol=crlf
*.sln            text eol=crlf
*.vcxproj        text eol=crlf
*.vcxproj.filters text eol=crlf
*.props          text eol=crlf

# Known binary file types — never normalise
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.bmp   binary
*.webp  binary
*.exe   binary
*.dll   binary
*.lib   binary
*.pdb   binary
*.msi   binary
*.zip   binary
*.7z    binary
*.tar.gz binary
