# =============================================================
# Build artefacts (Windows C++ via MSBuild + CMake)
# =============================================================
*.exe
*.obj
*.pdb
*.ilk
*.idb
*.iobj
*.ipdb
*.map
*.exp
*.lib
*.res
*.tlog

# CMake build trees (one per agent target)
agents/*/build/

# Visual Studio per-user state
*.user
*.suo
*.opendb
*.sdf
*.VC.db
.vs/

# =============================================================
# Python (mcp-server, tests/conformance, client)
# =============================================================
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.venv/
venv/
env/

# =============================================================
# Editors / IDEs
# =============================================================
.vscode/
.idea/
*.swp
*.swo
*~

# =============================================================
# OS junk
# =============================================================
.DS_Store
Thumbs.db
desktop.ini

# =============================================================
# Project-local scratch (never committed)
# =============================================================
# Throwaway working directory used during development.
_TEMP/

# Conformance-test screenshot dumps and ad-hoc captures.
*.bmp
/tmp/

# =============================================================
# Vagrant local state (generated by `vagrant up`)
# =============================================================
examples/vagrant/.vagrant/
examples/vagrant/*.log

# =============================================================
# Claude Code per-user settings (machine-local; never committed)
# =============================================================
.claude/settings.local.json
